---
import AdminSidebar from "../components/admin/AdminSidebar.jsx";
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
        <script is:inline>
            const theme = localStorage.getItem("theme");
            if (
                theme === "dark" ||
                (!theme &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches)
            ) {
                document.documentElement.classList.add("dark");
            }
        </script>
    </head>
    <body
        class="bg-gray-50 dark:bg-black text-gray-900 dark:text-gray-100 transition-colors duration-200"
    >
        <div class="flex min-h-screen">
            {
                /* 
                Each sidebar item is now its own island or part of a single sidebar island.
                We use client:only because it needs window/localStorage and Kinde context.
            */
            }
            <AdminSidebar client:only="react" />

            <main class="flex-grow p-8 overflow-y-auto">
                <slot />
            </main>
        </div>
    </body>
</html>

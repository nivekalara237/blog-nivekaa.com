---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminPage from "../../components/AdminPage.jsx";
import { categories, tags } from "../../utils/api.js";

const allCategories = await categories;
const allTags = await tags;
---

<AdminLayout title="Créer un article | CloudNive Admin">
  <div class="mb-8 pl-4">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      Créer un nouvel article
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mt-2">
      Remplissez le formulaire ci-dessous pour publier un nouveau contenu.
    </p>
  </div>

  {/* AdminPage no longer needs its own ClerkProvider as it's in AdminLayout */}
  <AdminPage client:only="react" categories={allCategories} tags={allTags} />
</AdminLayout>

---
import Layout from '../../layouts/Layout.astro';
import ArticleEditor from '../../components/admin/ArticleEditor.jsx';
import { categories, tags } from '../../utils/api.js';

const allCategories = await categories;
const allTags = await tags;
---

<Layout title="Créer un article - MyBlog">
  <section class="max-w-4xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Créer un nouvel article</h1>
      <p class="text-gray-500 mt-2">Remplissez le formulaire ci-dessous pour publier un nouveau contenu.</p>
    </div>

    <ArticleEditor 
      client:load 
      categories={allCategories} 
      tags={allTags} 
    />
  </section>
</Layout>

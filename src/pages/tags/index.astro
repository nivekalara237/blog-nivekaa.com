---
import Layout from '../../layouts/Layout.astro';
import { getTags } from '../../utils/api.js';

const tags = await getTags();
---

<Layout title="Tags - MyBlog">
  <section class="max-w-4xl mx-auto text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-12">Explorer par tags</h1>
    
    <div class="flex flex-wrap justify-center gap-4">
      {tags.map(tag => (
        <a 
          href={`/tags`} 
          class="bg-white text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-6 py-3 rounded-full font-medium transition-all duration-300 shadow-sm border border-gray-200"
        >
          #{tag}
        </a>
      ))}
    </div>
  </section>
</Layout>

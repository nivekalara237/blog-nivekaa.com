---
import Layout from "../../layouts/Layout.astro";
import ArticleCard from "../../components/ArticleCard.jsx";
import Pagination from "../../components/Pagination.astro";
import { api } from "../../lib/api";

export async function getStaticPaths({ paginate }: any) {
    const response = await api.getArticles();
    const articles = response.items || [];

    // Sort by date descending (newest first)
    articles.sort(
        (a: any, b: any) =>
            new Date(b.date).getTime() - new Date(a.date).getTime(),
    );

    // Note: We use pageSize 3 to match index.astro, but this handles page 2, 3, etc.
    // The first page of this collection (page 1) technically duplicates index,
    // but in our architecture we link index's "Next" to /page/2.
    return paginate(articles, { pageSize: 24 });
}

const { page } = Astro.props;
---

<Layout title={`Articles - Page ${page.currentPage}`}>
    <section class="mb-12">
        <h1 class="text-3xl font-bold text-gray-900 mb-8">
            Tous les articles (Page {page.currentPage})
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                page.data.map((article: any) => (
                    <ArticleCard client:load article={article} />
                ))
            }
        </div>

        <Pagination page={page} />
    </section>
</Layout>

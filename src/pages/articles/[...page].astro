---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.jsx';
import { getArticles } from '../../utils/api.js';

export async function getStaticPaths({ paginate }) {
  const articles = await getArticles();
  return paginate(articles, { pageSize: 6 });
}

const { page } = Astro.props;
---

<Layout title="Articles - MyBlog">
  <section class="mb-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Tous les articles</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {page.data.map(article => (
        <ArticleCard article={article} />
      ))}
    </div>

    <div class="mt-12 flex justify-center space-x-4">
      {page.url.prev ? (
        <a href={page.url.prev} class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-md font-medium transition-colors">
          &larr; Précédent
        </a>
      ) : null}
      
      {page.url.next ? (
        <a href={page.url.next} class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-md font-medium transition-colors">
          Suivant &rarr;
        </a>
      ) : null}
    </div>
  </section>
</Layout>

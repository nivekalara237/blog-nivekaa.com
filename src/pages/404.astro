---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Introuvable">
    <div
        class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4 relative overflow-hidden"
    >
        {/* Decorative background elements */}
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"
        >
        </div>
        <div
            class="absolute top-1/3 left-1/3 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"
        >
        </div>

        <div class="relative z-10">
            <h1
                class="text-9xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 to-purple-300 opacity-50 select-none"
            >
                404
            </h1>

            <div class="-mt-8 mb-8 space-y-4">
                <h2
                    class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100"
                >
                    Oups ! Page introuvable
                </h2>
                <p
                    class="text-lg text-gray-600 dark:text-gray-400 max-w-lg mx-auto"
                >
                    Il semble que vous soyez perdu dans les nuages. La page que
                    vous recherchez n'existe pas ou a été déplacée.
                </p>
            </div>

            <div
                class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-8"
            >
                <a
                    href="/"
                    class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-full shadow-lg shadow-indigo-500/30 transition-all hover:scale-105 hover:shadow-indigo-500/50 flex items-center gap-2"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                        ></path>
                    </svg>
                    Retour à l'accueil
                </a>

                <a
                    href="/articles"
                    class="px-8 py-3 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 font-semibold rounded-full border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-all hover:scale-105"
                >
                    Voir les articles
                </a>
            </div>
        </div>

        {/* Animated cloud icon */}
        <div
            class="mt-16 text-indigo-200 dark:text-indigo-900/30 animate-pulse"
        >
            <svg
                class="w-24 h-24 mx-auto"
                fill="currentColor"
                viewBox="0 0 20 20"
            >
                <path
                    d="M5.5 16a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.977A4.5 4.5 0 1113.5 16h-8z"
                ></path>
            </svg>
        </div>
    </div>
</Layout>

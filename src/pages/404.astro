---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Introuvable">
    <div
        class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4 relative overflow-hidden"
    >
        {/* Decorative background grid */}
        <div class="absolute inset-0 z-0 pointer-events-none" style="background-image: radial-gradient(var(--bg-border) 1px, transparent 1px); background-size: 30px 30px; opacity: 0.1;"></div>

        <div class="relative z-10 w-full max-w-2xl">
            {/* Terminal-like Window */}
            <div
                style="background:var(--bg-surface); border:3px solid var(--green-dark); box-shadow: inset 2px 2px 0 rgba(255,255,255,0.03), 8px 8px 0 rgba(0,0,0,0.4), 0 0 30px rgba(35,114,39,0.1);"
                class="text-left overflow-hidden"
            >
                {/* Terminal Title Bar */}
                <div
                    class="flex items-center gap-2 px-4 py-3"
                    style="background:var(--bg-panel); border-bottom:2px solid var(--green-dark);"
                >
                    <span style="width:10px;height:10px;background:#FF5F56;border:2px solid #FF5F56;display:inline-block;"></span>
                    <span style="width:10px;height:10px;background:#FFBB2C;border:2px solid #FFBB2C;display:inline-block;"></span>
                    <span style="width:10px;height:10px;background:var(--green-light);border:2px solid var(--green-light);display:inline-block;"></span>
                    <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-dim);margin-left:8px;">
                        cloud@nivekaa ~ error
                    </span>
                </div>

                {/* Terminal Body */}
                <div class="p-6 md:p-8" style="font-family:'JetBrains Mono',monospace; font-size:14px; line-height:1.8;">
                    <div class="mb-4">
                        <span style="color:var(--green-light); font-weight:bold;">$</span>
                        <span style="color:var(--text-primary); margin-left: 8px;">curl https://cloud.nivekaa.com/votre-requête</span>
                    </div>
                    
                    <div style="color:#FF5F56; font-weight:bold; margin-bottom: 8px;">
                        > HTTP/1.1 404 Not Found
                    </div>

                    <div style="color:var(--text-secondary); margin-bottom: 24px;">
                        <span style="color:var(--yellow-dark);">Error:</span> Le fichier ou la ressource demandée n'existe pas ou a été déplacée.
                    </div>

                    {/* Fun decorative logs */}
                    <div class="text-xs md:text-sm mb-8" style="color:var(--text-dim); opacity: 0.7;">
                        [log] Attempting connection to destination... failed.<br/>
                        [log] Searching index routes... no match found.<br/>
                        [log] Redirecting to fallback protocol.
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 mt-6">
                        <a href="/" class="btn btn--gold" style="font-size: 13px;">
                            ▶ cd /home
                        </a>
                        <a href="/articles" class="btn btn--secondary" style="font-size: 13px;">
                            // ls /articles
                        </a>
                    </div>

                    <div class="mt-8 flex items-center gap-2">
                        <span style="color:var(--green-light); font-weight:bold;">$</span>
                        <span style="display:inline-block;width:8px;height:15px;background:var(--green-light);animation:blink 1.1s step-end infinite;vertical-align:middle;margin-left:2px;"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    @keyframes blink {
        50% {
            opacity: 0;
        }
    }
</style>

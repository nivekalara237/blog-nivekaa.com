---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } }
  ];
}

const SITE_URL = 'https://cloud.nivekaa.com';
const { lang: paramLang } = Astro.params;
const lang = paramLang === 'fr' ? 'fr' : 'en';

const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || '/about';
---

<Layout 
  title={lang === 'fr' ? "À propos - CloudNive" : "About - CloudNive"}
  lang={lang}
  hreflangEn={`${SITE_URL}${currentPath}`}
  hreflangFr={`${SITE_URL}/fr${currentPath}`}
>
  <section class="max-w-4xl mx-auto px-6 py-12">
    
    <div class="mb-8 flex items-center gap-4">
      <span style="color:var(--yellow-dark); font-size:14px;">▶</span>
      <h1 class="m-0" style="font-family:'Space Grotesk',sans-serif; font-weight:900; font-size:clamp(28px,4vw,42px); color:var(--text-primary); text-transform:uppercase; letter-spacing:-1px;">
        {lang === 'fr' ? 'À propos de Cloud' : 'About Cloud'}<span style="color:var(--green-light)">Nive</span>
      </h1>
    </div>

    {/* Main Terminal Window */}
    <div
        style="background:var(--bg-surface); border:3px solid var(--bg-border); box-shadow: inset 2px 2px 0 rgba(255,255,255,0.03), 8px 8px 0 rgba(0,0,0,0.4);"
        class="overflow-hidden mb-12"
    >
        {/* Terminal Title Bar */}
        <div
            class="flex items-center gap-2 px-4 py-3"
            style="background:var(--bg-panel); border-bottom:2px solid var(--bg-border);"
        >
            <span style="width:10px;height:10px;background:#FF5F56;border:2px solid #FF5F56;display:inline-block;"></span>
            <span style="width:10px;height:10px;background:#FFBB2C;border:2px solid #FFBB2C;display:inline-block;"></span>
            <span style="width:10px;height:10px;background:var(--green-light);border:2px solid var(--green-light);display:inline-block;"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-dim);margin-left:8px;">
                cat /var/www/about/mission.txt
            </span>
        </div>

        {/* Terminal Body */}
        <div class="p-6 md:p-8" style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.8; color:var(--text-secondary);">
            <p class="mb-6">
                <span style="color:var(--green-light); font-weight:bold;">> INITIALIZING:</span> {lang === 'fr' 
                  ? "Bienvenue sur CloudNive, votre source d'information privilégiée sur le développement logiciel moderne, le cloud computing et les architectures serverless."
                  : "Welcome to CloudNive, your primary source of information on modern software development, cloud computing, and serverless architectures."}
            </p>
            
            <p class="mb-6">
                {lang === 'fr' 
                  ? "Notre mission est de partager des connaissances techniques approfondies, des tutoriels pratiques et des retours d'expérience pour aider les développeurs à construire des applications plus performantes et plus évolutives dans l'écosystème Cloud (AWS, Azure, Terraform, Kubernetes)."
                  : "Our mission is to share in-depth technical knowledge, practical tutorials, and experience feedback to help developers build more performant and scalable applications within the Cloud ecosystem (AWS, Azure, Terraform, Kubernetes)."}
            </p>

            <div class="my-8" style="height:1px; background:var(--bg-border);"></div>

            <h2 class="mb-4" style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:24px; color:var(--text-primary);">
                <span style="color:var(--yellow-dark);">#</span> {lang === 'fr' ? "L'équipe" : "The Team"}
            </h2>
            <p>
                {lang === 'fr' 
                  ? "Nous sommes une équipe de passionnés de technologie, toujours à l'affût des dernières nouveautés dans l'écosystème Cloud et DevOps. Chaque article publié ici est conçu comme un \"niveau\" supplémentaire pour vous aider à monter en compétence."
                  : "We are a team of tech enthusiasts, always on the lookout for the latest in the Cloud and DevOps ecosystem. Each article published here is designed as an extra \"level\" to help you upgrade your skills."}
            </p>

            <div class="mt-8 flex items-center gap-2" style="font-family:'JetBrains Mono',monospace;">
                <span style="color:var(--green-light); font-weight:bold;">$</span>
                <span style="color:var(--text-primary);">exit 0</span>
            </div>
            <div class="mt-2 flex items-center gap-2">
                <span style="color:var(--green-light); font-weight:bold;">$</span>
                <span style="display:inline-block;width:8px;height:15px;background:var(--green-light);animation:blink 1.1s step-end infinite;vertical-align:middle;margin-left:2px;"></span>
            </div>
        </div>
    </div>

  </section>
</Layout>

<style>
    @keyframes blink {
        50% {
            opacity: 0;
        }
    }
</style>

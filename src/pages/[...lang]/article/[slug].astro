---
import Layout from "../../../layouts/Layout.astro";
import { api } from "../../../lib/api";
import MarkdownRenderer from "../../../components/MarkdownRenderer.jsx";
import TableOfContents from "../../../components/TableOfContents.jsx";
import PublicAuthorCard from "../../../components/PublicAuthorCard.jsx";
import AdPanel from "../../../components/AdPanel.jsx";
import CoverImage from "../../../components/CoverImage.jsx";
import { DEFAULT_AUTHOR } from "../../../config/author";
import { ADS_ENABLED, AD_CONFIG, AD_SLOTS } from "../../../config/ads";
import { useTranslations } from "../../../i18n/utils";

// Active le mode statique (SSG)
export const prerender = true;

const SITE_URL = 'https://cloud.nivekaa.com';

export async function getStaticPaths() {
    const SITE_URL = 'https://cloud.nivekaa.com';
    const dataEn = await api.getArticles({ limit: 1000, lang: 'en' });
    const dataFr = await api.getArticles({ limit: 1000, lang: 'fr' });
    
    const articlesEn = Array.isArray(dataEn) ? dataEn : dataEn.items || [];
    const articlesFr = Array.isArray(dataFr) ? dataFr : dataFr.items || [];

    const paths: any[] = [];

    articlesEn.forEach((article: any) => {
        paths.push({
            params: { lang: undefined, slug: article.slug },
            props: {
                article,
                lang: 'en',
                hreflangEn: `${SITE_URL}/article/${article.slug}`,
                hreflangFr: article.translationAvailable ? `${SITE_URL}/fr/article/${article.slug}` : undefined,
            }
        });
    });

    articlesFr.forEach((article: any) => {
        // Assume article object from FR query is already translated
        paths.push({
            params: { lang: 'fr', slug: article.slug },
            props: {
                article,
                lang: 'fr',
                hreflangEn: article.translationAvailable ? `${SITE_URL}/article/${article.slug}` : undefined,
                hreflangFr: `${SITE_URL}/fr/article/${article.slug}`,
            }
        });
    });

    return paths;
}

const { article, lang, hreflangEn, hreflangFr }: any = Astro.props;

// Use article author or default author
const author = article.author || DEFAULT_AUTHOR;

// Calculate reading time (assuming 200 words per minute)
const content = article.content || article.contentMarkdown;
const wordCount = content?.split(/\s+/).length || 0;
const readingTime = Math.ceil(wordCount / 200);

// Format date
const formatDate = (dateStr: string) => {
    const date = new Date(dateStr);
    return date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};
const siteUrl = Astro.site || SITE_URL;
const articleUrl = new URL(Astro.url.pathname, siteUrl);

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: article.title,
    description: article.description,
    image: article.cover ? new URL(article.cover, siteUrl) : undefined,
    datePublished: article.date,
    dateModified: article.lastUpdated || article.date,
    author: {
        "@type": "Person",
        name: author.name,
        jobTitle: author.role,
        image: author.avatar,
    },
    publisher: {
        "@type": "Organization",
        name: "CloudNive",
        logo: {
            "@type": "ImageObject",
            url: new URL("/favicon.svg", siteUrl),
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": articleUrl,
    },
};
---

<Layout
    title={`${article.title}`}
    description={article.description}
    image={article.cover}
    type="article"
    lang={lang}
    hreflangEn={hreflangEn}
    hreflangFr={hreflangFr}
>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
        <!-- Cover Image or Gradient Fallback -->
        <CoverImage
            client:load
            cover={article.cover}
            title={article.title}
            category={article.category}
            slug={article.slug}
        />

        <!-- Tags (right after image) -->
        <div class="max-w-4xl ml-0 mb-6">
            {
                article.tags && article.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                        {article.tags.map((tag: any) => (
                            <span class="game-tag">#{tag}</span>
                        ))}
                    </div>
                )
            }
        </div>

        <!-- Article Header Section -->
        <div class="max-w-4xl ml-0 mb-10">
            <!-- Title -->
            <h1
                class="mb-6 leading-tight"
                style="font-family:'Space Grotesk',sans-serif; font-weight:900; font-size:clamp(28px,4vw,48px); letter-spacing:-1px; color:var(--text-primary);"
            >
                {article.title}
            </h1>

            <!-- Author Info -->
            <div class="flex items-center gap-3 mb-5">
                <img
                    src={author.avatar}
                    alt={author.name}
                    class="w-12 h-12 rounded-full border-2 border-gray-200 dark:border-gray-700"
                />
                <div>
                    <div
                        class="text-sm font-semibold text-gray-900 dark:text-gray-100"
                    >
                        {author.name}
                    </div>
                    <div class="text-xs text-gray-600 dark:text-gray-400">
                        {author.role}
                    </div>
                </div>
            </div>

            <!-- Date & Reading Time & Category -->
            <div
                class="flex flex-wrap items-center gap-2 text-xs text-gray-500 dark:text-gray-500"
            >
                <time>{formatDate(article.date)}</time>
                <span>•</span>
                <span>{readingTime} {lang === 'fr' ? 'min de lecture' : 'min read'}</span>
                <span>•</span>
                <span class="font-medium" style="color:var(--green-light);"
                    >{article.category}</span
                >
            </div>
        </div>

        <!-- Ad Before Content -->
        {
            ADS_ENABLED && AD_CONFIG.showBeforeContent && (
                <AdPanel
                    client:load
                    ad={AD_SLOTS.beforeContent}
                    variant="banner"
                />
            )
        }

        <!-- Two Column Layout: Content + TOC -->
        <div class="lg:flex lg:gap-8">
            <!-- Main Content -->
            <article class="lg:w-3/4">
                <div class="pixel-box-removed-tmp pb-8 md:pb-12 mb-8">
                    <div class="prose max-w-none">
                        <MarkdownRenderer client:load content={content} />
                    </div>
                </div>

                <!-- Ad After Content -->
                {
                    ADS_ENABLED && AD_CONFIG.showAfterContent && (
                        <AdPanel
                            client:load
                            ad={AD_SLOTS.afterContent}
                            variant="card"
                        />
                    )
                }

                <!-- Author Card (Always displayed with fallback to default) -->
                <PublicAuthorCard client:load author={author} />
            </article>

            <!-- Sidebar: Table of Contents (hidden on mobile) -->
            <aside class="hidden lg:block lg:w-1/4">
                <TableOfContents client:load content={content} />

                <!-- Ad in Sidebar -->
                {
                    ADS_ENABLED && AD_CONFIG.showInSidebar && (
                        <AdPanel
                            client:load
                            ad={AD_SLOTS.sidebar}
                            variant="sidebar"
                        />
                    )
                }
            </aside>
        </div>
    </div>
</Layout>

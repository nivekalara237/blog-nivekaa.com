---
import Layout from '../../../layouts/Layout.astro';
import { getTags } from '../../../utils/api.js';

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } }
  ];
}

const { lang: paramLang } = Astro.params;
const lang = paramLang === 'fr' ? 'fr' : 'en';

const SITE_URL = 'https://cloud.nivekaa.com';
const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || '/tags';

const tags = await getTags();
---

<Layout 
  title={lang === 'fr' ? "Tags - MyBlog" : "Tags - MyBlog"}
  lang={lang}
  hreflangEn={`${SITE_URL}${currentPath}`}
  hreflangFr={`${SITE_URL}/fr${currentPath}`}
>
  <section class="max-w-4xl mx-auto text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-12">{lang === 'fr' ? 'Explorer par tags' : 'Explore by tags'}</h1>
    
    <div class="flex flex-wrap justify-center gap-4">
      {tags.map(tag => (
        <a 
          href={lang === 'fr' ? `/fr/tags` : `/tags`} 
          class="bg-white text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 px-6 py-3 rounded-full font-medium transition-all duration-300 shadow-sm border border-gray-200"
        >
          #{tag}
        </a>
      ))}
    </div>
  </section>
</Layout>

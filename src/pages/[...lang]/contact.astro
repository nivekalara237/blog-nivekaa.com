---
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/ContactForm.jsx";
import { useTranslations } from "../../i18n/utils";

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } }
  ];
}

const SITE_URL = 'https://cloud.nivekaa.com';
const { lang: paramLang } = Astro.params;
const lang = paramLang === 'fr' ? 'fr' : 'en';
const t = useTranslations(lang);

const getTransl = (key: Parameters<typeof t>[0], fallback: string) => t(key) || fallback;
---

<Layout
  title="Contact - CloudNive Blog"
  description="Contact us for any questions, collaboration or feedback on Cloud and DevOps."
  lang={lang}
  hreflangEn={`${SITE_URL}/contact`}
  hreflangFr={`${SITE_URL}/fr/contact`}
>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
      <div
        class="inline-block px-3 py-1 mb-4 text-[10px] font-bold uppercase tracking-[0.2em]"
        style="background: rgba(var(--yellow-dark-rgb), 0.1); border: 1px solid var(--yellow-dark); color: var(--yellow-light);"
      >
        {lang === 'fr' ? 'Canal de Communication' : 'Communication Channel'}
      </div>
      <h1
        class="text-4xl md:text-5xl font-black mb-4 uppercase italic"
        style="font-family: 'Space Grotesk', sans-serif; letter-spacing: -1px; background: linear-gradient(to right, var(--text-primary), var(--text-dim)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
      >
        Contact <span
          style="color: var(--yellow-dark); -webkit-text-fill-color: var(--yellow-dark);"
          >_</span
        >
      </h1>
      <p
        class="text-[var(--text-secondary)] max-w-xl mx-auto leading-relaxed"
        style="font-family: 'Inter', sans-serif;"
      >
        {lang === 'fr' 
          ? 'Envoyez-nous un message. Notre équipe technique vous répondra dans les plus brefs délais via une connexion sécurisée.'
          : 'Send us a message. Our technical team will get back to you as soon as possible via a secure connection.'}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Info Sidebar -->
      <div class="lg:col-span-1 space-y-8">
        <div class="pixel-box p-6" style="background: var(--bg-surface);">
          <h3
            class="text-xs font-black uppercase mb-4 tracking-widest text-[var(--yellow-dark)]"
            style="font-family: 'JetBrains Mono', monospace;"
          >
            // {lang === 'fr' ? 'Accès Direct' : 'Direct Access'}
          </h3>
          <div class="space-y-4">
            <a
              href="mailto:contact@nivekaa.com"
              class="group flex items-center gap-3 text-sm hover:text-[var(--yellow-dark)] transition-colors"
            >
              <span
                class="w-8 h-8 flex items-center justify-center border border-[var(--bg-border)] group-hover:border-[var(--yellow-dark)] transition-colors"
                >✉</span
              >
              <span>contact@nivekaa.com</span>
            </a>
            <div class="flex items-center gap-3 text-sm text-[var(--text-dim)]">
              <span
                class="w-8 h-8 flex items-center justify-center border border-[var(--bg-border)]"
                >🌍</span
              >
              <span>Remote First / Paris, FR</span>
            </div>
          </div>
        </div>

        <div
          class="pixel-box p-6 hidden"
          style="background: var(--bg-surface);"
        >
          <h3
            class="text-xs font-black uppercase mb-4 tracking-widest text-[var(--green-light)]"
            style="font-family: 'JetBrains Mono', monospace;"
          >
            // System Status
          </h3>
          <div class="space-y-3">
            <div
              class="flex items-center justify-between text-[10px] uppercase font-bold"
            >
              <span class="text-[var(--text-dim)]">Server</span>
              <span class="text-[var(--green-light)]">Bf-109 / Online</span>
            </div>
            <div class="w-full h-1 bg-[var(--bg-deep)]">
              <div class="h-full bg-[var(--green-dark)]" style="width: 100%;">
              </div>
            </div>
            <div
              class="flex items-center justify-between text-[10px] uppercase font-bold"
            >
              <span class="text-[var(--text-dim)]">Uptime</span>
              <span class="text-[var(--green-light)]">99.99%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <ContactForm client:load lang={lang} />
      </div>
    </div>
  </main>
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import NotesApp from "../../../components/notes-v2/NotesApp.jsx";

export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } }
  ];
}

const { lang: paramLang } = Astro.params;
const lang = paramLang === 'fr' ? 'fr' : 'en';

const SITE_URL = 'https://cloud.nivekaa.com';
const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || '/notes-v2';
---

<Layout 
  title={lang === 'fr' ? "Notes Techniques — CloudNive" : "Technical Notes — CloudNive"}
  description={lang === 'fr' 
    ? "Consultez et organisez vos notes techniques de manière hiérarchique."
    : "View and organize your technical notes in a hierarchical structure."}
  lang={lang}
  hreflangEn={`${SITE_URL}${currentPath}`}
  hreflangFr={`${SITE_URL}/fr${currentPath}`}
>
  <NotesApp client:only="react" lang={lang} isAdmin={false} />
</Layout>

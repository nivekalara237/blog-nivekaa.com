---
import Layout from "../../../../layouts/Layout.astro";
import ArticleCard from "../../../../components/ArticleCard.jsx";
import Pagination from "../../../../components/Pagination.astro";
import { api } from "../../../../lib/api";
import { getCategories } from "../../../../utils/api";

export async function getStaticPaths({ paginate }: any) {
    const categories = await getCategories();
    
    // Fetch articles for both languages
    const responseEn = await api.getArticles({ limit: 1000, lang: 'en' });
    const responseFr = await api.getArticles({ limit: 1000, lang: 'fr' });
    
    let articlesEn = responseEn.items || [];
    let articlesFr = responseFr.items || [];

    const sortFn = (a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime();
    articlesEn.sort(sortFn);
    articlesFr.sort(sortFn);

    const enPaths = categories.flatMap((category) => {
        const filteredArticles = articlesEn.filter((article: any) => article.category === category);
        return paginate(filteredArticles, {
            params: { lang: undefined, category },
            pageSize: 24,
        });
    });

    const frPaths = categories.flatMap((category) => {
        const filteredArticles = articlesFr.filter((article: any) => article.category === category);
        return paginate(filteredArticles, {
            params: { lang: 'fr', category },
            pageSize: 24,
        });
    });

    return [...enPaths, ...frPaths];
}

export const prerender = true;

const { page } = Astro.props as any;
const { category, lang: paramLang }: any = Astro.params;
const lang = paramLang === 'fr' ? 'fr' : 'en';

const SITE_URL = 'https://cloud.nivekaa.com';
const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || `/category/${category}`;
---

<Layout 
    title={lang === 'fr' ? `Articles - ${category}` : `Articles - ${category}`}
    lang={lang}
    hreflangEn={`${SITE_URL}${currentPath}`}
    hreflangFr={`${SITE_URL}/fr${currentPath}`}
>
    <section class="max-w-7xl mx-auto px-6 lg:px-8 mb-12 py-12">
        <div
            class="mb-8 border-b-2 pb-6"
            style="border-color: var(--bg-border);"
        >
            <a
                href={lang === 'fr' ? "/fr/categories" : "/categories"}
                style="font-family:'Inter',sans-serif; font-size:14px; color:var(--text-dim); text-decoration:none; display:inline-block; margin-bottom:16px;"
                onmouseover="this.style.color='var(--green-light)'"
                onmouseout="this.style.color='var(--text-dim)'"
            >
                &larr; {lang === 'fr' ? 'Toutes les catégories' : 'All categories'}
            </a>
            <h1
                class="m-0"
                style="font-family:'Space Grotesk',sans-serif; font-weight:900; font-size:clamp(28px,4vw,40px); line-height:1.1; letter-spacing:-1px; color:var(--text-primary);"
            >
                {lang === 'fr' ? 'Catégorie' : 'Category'} <span style="color:var(--yellow-dark);"
                    >//{category}</span
                >
            </h1>
        </div>

        {
            page.data.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {page.data.map((article: any) => (
                        <ArticleCard client:load article={article} />
                    ))}
                </div>
            ) : (
                <div
                    class="pixel-box p-12 text-center"
                    style="background:var(--bg-panel);"
                >
                    <p style="font-family:'JetBrains Mono',monospace; color:var(--text-secondary); font-size:16px;">
                        {lang === 'fr' ? 'Aucun article trouvé dans cette catégorie.' : 'No articles found in this category.'}
                    </p>
                    <a
                        href={lang === 'fr' ? "/fr/articles" : "/articles"}
                        class="btn btn--secondary mt-6 inline-block"
                    >
                        {lang === 'fr' ? 'Voir tous les articles' : 'View all articles'}
                    </a>
                </div>
            )
        }

        <Pagination page={page} lang={lang} />
    </section>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { getCategories, getArticles } from "../../utils/api.js";
import { getCategoryIconComponent } from "../../components/IconHelper.jsx";

const categoriesList = await getCategories();
const allArticles = await getArticles();

// Calculate counts
const categories = categoriesList.map((name) => {
  const count = allArticles.filter(
    (article) => article.category === name,
  ).length;
  return { name, count };
});
---

<Layout title="Catégories - MyBlog">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12 border-b-2 pb-6" style="border-color: var(--bg-border);">
      <h1
        class="m-0 mb-3"
        style="font-family:'Space Grotesk',sans-serif; font-weight:900; font-size:clamp(28px,4vw,40px); line-height:1.1; letter-spacing:-1px; color:var(--text-primary);"
      >
        Base de données <span style="color:var(--yellow-dark);"
          >//Catégories</span
        >
      </h1>
      <p
        style="font-family:'Inter',sans-serif; font-size:16px; color:var(--text-secondary); max-width:600px; margin:0;"
      >
        Filtrez nos articles par thématique technique. Choisissez votre zone
        d'exploration.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-16"
    >
      {
        categories.map((category) => {
          const IconComponent = getCategoryIconComponent(category.name);

          return (
            <a
              href={`/category/${category.name}`}
              class="group block h-full no-underline"
            >
              <div
                class="pixel-box p-8 flex flex-col items-center text-center h-full min-h-[180px] justify-center transition-all duration-100"
                style="background: var(--bg-surface);"
                onmouseover="this.style.borderColor='var(--green-dark)'; this.style.transform='translate(-3px,-3px)'; this.style.boxShadow='4px 4px 0 rgba(35,114,39,0.3)';"
                onmouseout="this.style.borderColor='var(--bg-border)'; this.style.transform='translate(0,0)'; this.style.boxShadow='4px 4px 0 rgba(0,0,0,0.5)';"
              >
                <div
                  class="mb-5"
                  style="color:var(--yellow-dark); transition:color 0.1s;"
                >
                  <IconComponent className="h-10 w-10 text-current transition-colors" />
                </div>
                <h3
                  class="m-0 mb-3 uppercase tracking-widest"
                  style="font-family:'Inter',sans-serif; font-weight:700; font-size:14px; color:var(--text-primary);"
                >
                  {category.name}
                </h3>
                <div style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--green-light); padding:2px 8px; background:rgba(35,114,39,0.15); border:1px solid var(--green-dark);">
                  Lv. {category.count}{" "}
                  <span style="color:var(--text-dim);">(articles)</span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getCategories } from '../../utils/api.js';

const categories = await getCategories();
---

<Layout title="Catégories - MyBlog">
  <section class="max-w-4xl mx-auto text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-12">Explorer par catégories</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map(category => (
        <a 
          href={`/categories`} 
          class="group bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100"
        >
          <h2 class="text-xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors">
            {category}
          </h2>
        </a>
      ))}
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getArticles } from '../../utils/api.js';

export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<Layout title={`${article.title} - MyBlog`} description={article.description}>
  <article class="max-w-3xl mx-auto bg-white rounded-2xl shadow-sm overflow-hidden">
    <img 
      src={article.cover} 
      alt={article.title} 
      class="w-full h-64 md:h-96 object-cover"
    />
    <div class="p-8 md:p-12">
      <div class="flex items-center justify-between mb-6">
        <span class="text-indigo-600 font-medium bg-indigo-50 px-3 py-1 rounded-full">
          {article.category}
        </span>
        <time class="text-gray-500">{article.date}</time>
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        {article.title}
      </h1>

      <div class="prose prose-lg prose-indigo max-w-none">
        <Fragment set:html={article.html} />
      </div>

      <div class="mt-12 pt-8 border-t border-gray-100">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {article.tags.map(tag => (
            <span class="text-gray-600 bg-gray-100 px-3 py-1 rounded-lg text-sm">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  </article>
</Layout>

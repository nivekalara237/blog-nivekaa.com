---
import Layout from "../../../layouts/Layout.astro";
import ArticleCard from "../../../components/ArticleCard.jsx";
import Pagination from "../../../components/Pagination.astro";
import { api } from "../../../lib/api";
import { getCategories } from "../../../utils/api";

export async function getStaticPaths({ paginate }: any) {
    const response = await api.getArticles();
    const articles = response.items || [];
    const categories = await getCategories();

    // Sort by date (newest first)
    articles.sort(
        (a: any, b: any) =>
            new Date(b.date).getTime() - new Date(a.date).getTime(),
    );

    // Generate paths for each category
    return categories.flatMap((category) => {
        const filteredArticles = articles.filter(
            (article: any) => article.category === category,
        );

        return paginate(filteredArticles, {
            params: { category },
            pageSize: 24,
        });
    });
}

export const prerender = true;
const { page } = Astro.props as any;
const { category } = Astro.params;
---

<Layout title={`Articles - ${category}`}>
    <section class="max-w-7xl mx-auto px-6 lg:px-8 mb-12 py-12">
        <div
            class="mb-8 border-b-2 pb-6"
            style="border-color: var(--bg-border);"
        >
            <a
                href="/categories"
                style="font-family:'Inter',sans-serif; font-size:14px; color:var(--text-dim); text-decoration:none; display:inline-block; margin-bottom:16px;"
                onmouseover="this.style.color='var(--green-light)'"
                onmouseout="this.style.color='var(--text-dim)'"
            >
                &larr; Toutes les catégories
            </a>
            <h1
                class="m-0"
                style="font-family:'Space Grotesk',sans-serif; font-weight:900; font-size:clamp(28px,4vw,40px); line-height:1.1; letter-spacing:-1px; color:var(--text-primary);"
            >
                Catégorie <span style="color:var(--yellow-dark);"
                    >//{category}</span
                >
            </h1>
        </div>

        {
            page.data.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {page.data.map((article: any) => (
                        <ArticleCard client:load article={article} />
                    ))}
                </div>
            ) : (
                <div
                    class="pixel-box p-12 text-center"
                    style="background:var(--bg-panel);"
                >
                    <p style="font-family:'JetBrains Mono',monospace; color:var(--text-secondary); font-size:16px;">
                        Aucun article trouvé dans cette catégorie.
                    </p>
                    <a
                        href="/articles"
                        class="btn btn--secondary mt-6 inline-block"
                    >
                        Voir tous les articles
                    </a>
                </div>
            )
        }

        <Pagination page={page} />
    </section>
</Layout>

---
import { languages } from '../i18n/ui';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const { pathname } = Astro.url;

// Strip any lang prefix to get the raw route path
const rawPath = pathname.replace(/^\/(fr)\//, '/').replace(/^\/(fr)$/, '/');
---

<div class="relative group inline-block">
  <button 
    class="flex items-center gap-1.5 px-2 py-1.5 text-xs font-bold uppercase tracking-widest no-underline transition-all duration-100"
    style="font-family: 'Inter', sans-serif; color: var(--text-secondary);"
    aria-label="Select language"
  >
    <span>{lang === 'en' ? '🇬🇧 EN' : '🇫🇷 FR'}</span>
    <svg class="w-3 h-3 opacity-50 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div 
    class="absolute right-0 mt-1 w-32 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right scale-95 group-hover:scale-100"
    style="background: var(--bg-deep); border: 2px solid var(--green-dark); box-shadow: 4px 4px 0 rgba(35,114,39,0.25); z-index: 100;"
  >
    <ul class="list-none m-0 p-1">
      {Object.entries(languages).map(([supportedLang, label]) => (
        <li>
          <a 
            href={translatePath(rawPath, supportedLang)}
            class={`block px-3 py-2 text-xs font-bold tracking-wider transition-colors no-underline ${lang === supportedLang ? 'bg-green-dark/20 text-yellow-light' : 'text-text-secondary hover:text-yellow-light hover:bg-green-dark/10'}`}
            style="font-family: 'Inter', sans-serif;"
          >
            {supportedLang === 'en' ? '🇬🇧 ' : '🇫🇷 '}
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

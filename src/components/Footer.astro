---
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../i18n/utils";

const currentYear = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer
  style="background: var(--bg-surface); border-top: 3px solid var(--bg-border);"
>
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div
          class="text-base font-black uppercase tracking-widest mb-3"
          style="font-family: 'Space Grotesk', sans-serif; color: var(--text-primary);"
        >
          Cloud<span style="color: var(--yellow-dark);">Nive</span>
        </div>
        <p
          class="text-sm mb-5"
          style="color: var(--text-secondary); font-family: 'Inter', sans-serif; line-height: 1.7;"
        >
          {lang === 'fr' 
            ? "Blog technique sur le Cloud, l'IaC et le développement logiciel. Chaque article = un niveau débloqué. 🎮"
            : "Technical blog on Cloud, IaC, and software development. Every article is a new level unlocked. 🎮"}
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="game-tag">☁ AWS</span>
          <span class="game-tag">⚙ Terraform</span>
          <span class="game-tag game-tag--gold">☸ K8s</span>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <div
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: 'Inter', sans-serif; color: var(--text-dim);"
        >
          <span style="color: var(--green-dark);">// </span>Navigation
        </div>
        <ul class="flex flex-col gap-2 list-none p-0 m-0">
          {
            [
              { label: t('nav.home'), href: "/" },
              { label: t('nav.articles'), href: "/articles" },
              { label: t('nav.categories'), href: "/categories" },
              { label: t('nav.contact'), href: "/contact" },
            ].map(({ label, href }) => (
              <li>
                <a
                  href={translatePath(href)}
                  class="text-sm no-underline footer-link flex items-center gap-2"
                  style="color: var(--text-secondary); font-family: 'Inter', sans-serif; font-weight: 600; transition: color 0.1s;"
                >
                  <span style="color: var(--green-dark); font-size: 10px;">
                    ▸
                  </span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Topics -->
      <div>
        <div
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: 'Inter', sans-serif; color: var(--text-dim);"
        >
          <span style="color: var(--green-dark);">// </span>{lang === 'fr' ? 'Sujets' : 'Topics'}
        </div>
        <ul class="flex flex-col gap-2 list-none p-0 m-0">
          {
            [
              { label: "Cloud AWS", href: "/category/Cloud" },
              { label: "Terraform", href: "/category/Terraform" },
              { label: "Kubernetes", href: "/category/Kubernetes" },
              { label: "Frontend", href: "/category/Frontend" },
              { label: "Backend", href: "/category/Backend" },
            ].map(({ label, href }) => (
              <li>
                <a
                  href={translatePath(href)}
                  class="text-sm no-underline footer-link flex items-center gap-2"
                  style="color: var(--text-secondary); font-family: 'Inter', sans-serif; font-weight: 600; transition: color 0.1s;"
                >
                  <span style="color: var(--green-dark); font-size: 10px;">
                    ▸
                  </span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Links -->
      <div>
        <div
          class="text-xs font-bold uppercase tracking-widest mb-4"
          style="font-family: 'Inter', sans-serif; color: var(--text-dim);"
        >
          <span style="color: var(--green-dark);">// </span>{lang === 'fr' ? 'Liens' : 'Links'}
        </div>
        <ul class="flex flex-col gap-2 list-none p-0 m-0">
          {
            [
              { label: t('nav.newsletter'), href: "#newsletter", translate: false },
              { label: lang === 'fr' ? 'À propos' : 'About', href: "/about", translate: true },
              { label: "GitHub", href: "https://github.com", translate: false },
              { label: "LinkedIn", href: "https://linkedin.com", translate: false },
            ].map(({ label, href, translate }) => (
              <li>
                <a
                  href={translate ? translatePath(href) : href}
                  class="text-sm no-underline footer-link flex items-center gap-2"
                  style="color: var(--text-secondary); font-family: 'Inter', sans-serif; font-weight: 600; transition: color 0.1s;"
                >
                  <span style="color: var(--green-dark); font-size: 10px;">
                    ▸
                  </span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-4"
      style="border-top: 2px solid var(--bg-border);"
    >
      <span
        class="text-xs"
        style="font-family: 'JetBrains Mono', monospace; color: var(--text-dim);"
      >
        // © {currentYear} CloudNive — {lang === 'fr' ? 'Mission: partager le savoir' : 'Mission: sharing knowledge'}
      </span>

      <!-- XP bar -->
      <div
        class="flex items-center gap-2"
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px;"
      >
        <span style="color: var(--text-dim);">SITE XP:</span>
        <div class="xp-bar-track" style="width: 80px;">
          <div class="xp-bar-fill" style="width: 88%;"></div>
        </div>
        <span style="color: var(--yellow-dark);">LVL 42</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--yellow-light) !important;
  }
</style>

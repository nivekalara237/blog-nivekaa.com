---
import DarkModeToggle from "./DarkModeToggle.jsx";
import MobileMenu from "./MobileMenu.jsx";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<header
    class="sticky top-0 z-50"
    style="background: var(--bg-deep); border-bottom: 3px solid var(--green-dark); box-shadow: 0 4px 0 rgba(35,114,39,0.25);"
>
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 no-underline group">
            <div
                class="w-9 h-9 flex items-center justify-center text-lg font-bold"
                style="background: var(--green-dark); border: 3px solid var(--green-light); box-shadow: 3px 3px 0 rgba(0,0,0,0.5); color: var(--yellow-light);"
            >
                ☁
            </div>
            <span
                class="text-sm font-black uppercase tracking-widest"
                style="font-family: 'Space Grotesk', sans-serif; color: var(--text-primary);"
            >
                Cloud<span style="color: var(--yellow-dark);">Nive</span>
            </span>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
            {
                [
                    { label: t('nav.home'), href: "/" },
                    { label: t('nav.notes-v2'), href: "/notes-v2", app: true },
                    // { label: t('nav.articles'), href: "/articles" },
                    { label: t('nav.categories'), href: "/categories" },
                    { label: t('nav.contact'), href: "/contact" },
                ].map(({ label, href, app = false }) => (
                    <li>
											{app && <a
                          href={translatePath(href)}
                          class="hidden sm:inline-flex btn btn--primary"
                          style="font-size: 9px; padding: 5px 10px;"
                      >
                         {label}
                      </a>}
											{!app && <a
                          href={translatePath(href)}
                          class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest no-underline transition-all duration-100 nav-link"
                          style="font-family: 'Inter', sans-serif; color: var(--text-secondary); border: 2px solid transparent; letter-spacing: 1.5px;"
                      >
												{label}
                      </a>}

                    </li>
                ))
            }
        </ul>

        <!-- Right actions -->
        <div class="flex items-center gap-2 md:gap-3">
            <LanguageSwitcher />
            <DarkModeToggle client:load />

            <a
                href="#newsletter"
                class="hidden sm:inline-flex btn btn--primary"
                style="font-size: 9px; padding: 5px 10px;"
            >
                ▶ {t('nav.newsletter')}
            </a>

            <!-- Mobile menu button -->
            <button
                id="mobile-menu-button"
                class="md:hidden p-2 transition-colors flex items-center justify-center cursor-pointer"
                style="border: 2px solid var(--bg-border); color: var(--yellow-dark); background: transparent; height: 38px; width: 38px; position: relative; z-index: 60;"
                aria-label="Open menu"
            >
                <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu -->
<MobileMenu client:load />

<style>
    .nav-link:hover {
        color: var(--yellow-light) !important;
        border-color: var(--green-dark) !important;
        background: rgba(35, 114, 39, 0.15);
    }
</style>

<script is:inline>
    // Use a more robust approach that works with MPAs and potential re-renders
    const setupMenu = () => {
        const button = document.getElementById("mobile-menu-button");
        if (button) {
            // Remove existing to avoid double listeners
            const newButton = button.cloneNode(true);
            button.parentNode.replaceChild(newButton, button);
            
            newButton.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();
                window.dispatchEvent(new CustomEvent("toggle-mobile-menu"));
            });
        }
    };

    // Run immediately
    setupMenu();
    
    // Also run on DOMContentLoaded to be sure
    document.addEventListener('DOMContentLoaded', setupMenu);
</script>

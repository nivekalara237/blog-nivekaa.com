---
import DarkModeToggle from "./DarkModeToggle.jsx";
import MobileMenu from "./MobileMenu.jsx";
import AuthButtons from "./AuthButtons.jsx";
---

<header
    class="sticky top-0 z-50"
    style="background: var(--bg-deep); border-bottom: 3px solid var(--green-dark); box-shadow: 0 4px 0 rgba(35,114,39,0.25);"
>
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 no-underline group">
            <div
                class="w-9 h-9 flex items-center justify-center text-lg font-bold"
                style="background: var(--green-dark); border: 3px solid var(--green-light); box-shadow: 3px 3px 0 rgba(0,0,0,0.5); color: var(--yellow-light);"
            >
                ☁
            </div>
            <span
                class="text-sm font-black uppercase tracking-widest"
                style="font-family: 'Space Grotesk', sans-serif; color: var(--text-primary);"
            >
                Cloud<span style="color: var(--yellow-dark);">Nive</span>
            </span>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
            {
                [
                    { label: "Accueil", href: "/" },
                    { label: "Articles", href: "/articles" },
                    { label: "Catégories", href: "/categories" },
                    { label: "Contact", href: "/contact" },
                ].map(({ label, href }) => (
                    <li>
                        <a
                            href={href}
                            class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest no-underline transition-all duration-100 nav-link"
                            style="font-family: 'Inter', sans-serif; color: var(--text-secondary); border: 2px solid transparent; letter-spacing: 1.5px;"
                        >
                            {label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- Right actions -->
        <div class="flex items-center gap-3">
            <div class="hidden md:block">
                <DarkModeToggle client:load />
            </div>

            <a
                href="#newsletter"
                class="hidden md:inline-flex btn btn--primary text-xs"
                style="font-size: 11px; padding: 7px 16px;"
            >
                ▶ Newsletter
            </a>

            <!-- Mobile menu button -->
            <button
                id="mobile-menu-button"
                class="md:hidden p-2 transition-colors"
                style="border: 2px solid var(--bg-border); color: var(--text-secondary); background: transparent;"
                aria-label="Open menu"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu -->
<MobileMenu client:load />

<style>
    .nav-link:hover {
        color: var(--yellow-light) !important;
        border-color: var(--green-dark) !important;
        background: rgba(35, 114, 39, 0.15);
    }
</style>

<script>
    const button = document.getElementById("mobile-menu-button");
    if (button) {
        button.addEventListener("click", () => {
            const event = new CustomEvent("toggle-mobile-menu");
            window.dispatchEvent(event);
        });
    }
</script>

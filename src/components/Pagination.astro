---
const { page } = Astro.props;

const totalPages = page.lastPage;
const currentPage = page.currentPage;
const range = 2;

let pages: (number | string)[] = [];
pages.push(1);

for (let i = currentPage - range; i <= currentPage + range; i++) {
    if (i > 1 && i < totalPages) {
        if (pages[pages.length - 1] !== i - 1) pages.push("...");
        pages.push(i);
    }
}

if (totalPages > 1) {
    if (pages[pages.length - 1] !== totalPages - 1) pages.push("...");
    pages.push(totalPages);
}

if (totalPages <= 7) {
    pages = Array.from({ length: totalPages }, (_, i) => i + 1);
}
---

{
    totalPages > 1 && (
        <nav
            class="flex justify-center items-center gap-2 mt-12 mb-8"
            aria-label="Pagination"
            style="font-family: 'JetBrains Mono', monospace;"
        >
            {/* Prev */}
            {page.url.prev ? (
                <a
                    href={page.url.prev}
                    class="pagination-btn"
                    aria-label="Previous page"
                    style={`
                    display:inline-flex; align-items:center; justify-content:center;
                    width:36px; height:36px;
                    background: var(--bg-surface);
                    border: 3px solid var(--bg-border);
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-size: 16px;
                    box-shadow: 3px 3px 0 rgba(0,0,0,0.4);
                    transition: all 0.1s;
                `}
                >
                    ◀
                </a>
            ) : (
                <span
                    style={`
                    display:inline-flex; align-items:center; justify-content:center;
                    width:36px; height:36px;
                    background: var(--bg-panel);
                    border: 3px solid var(--bg-border);
                    color: var(--text-dim);
                    font-size: 16px;
                    opacity: 0.4;
                `}
                >
                    ◀
                </span>
            )}

            {/* Page numbers */}
            {pages.map((pageNum) => (
                <>
                    {pageNum === "..." ? (
                        <span style="color: var(--text-dim); padding: 0 4px;">
                            …
                        </span>
                    ) : (
                        <a
                            href={
                                pageNum === 1
                                    ? "/articles"
                                    : `/page/${pageNum}`.replace(
                                          "/page/1",
                                          "/articles",
                                      )
                            }
                            class="pagination-num"
                            aria-current={
                                pageNum === currentPage ? "page" : undefined
                            }
                            style={`
                            display:inline-flex; align-items:center; justify-content:center;
                            width:36px; height:36px;
                            border: 3px solid;
                            text-decoration: none;
                            font-size: 12px;
                            font-weight: 700;
                            transition: all 0.1s;
                            box-shadow: 3px 3px 0 rgba(0,0,0,0.35);
                            ${
                                pageNum === currentPage
                                    ? "background:var(--green-dark); border-color:var(--green-light); color:var(--yellow-light);"
                                    : "background:var(--bg-surface); border-color:var(--bg-border); color:var(--text-secondary);"
                            }
                        `}
                        >
                            {String(pageNum).padStart(2, "0")}
                        </a>
                    )}
                </>
            ))}

            {/* Next */}
            {page.url.next ? (
                <a
                    href={page.url.next}
                    class="pagination-btn"
                    aria-label="Next page"
                    style={`
                    display:inline-flex; align-items:center; justify-content:center;
                    width:36px; height:36px;
                    background: var(--bg-surface);
                    border: 3px solid var(--bg-border);
                    color: var(--text-secondary);
                    text-decoration: none;
                    font-size: 16px;
                    box-shadow: 3px 3px 0 rgba(0,0,0,0.4);
                    transition: all 0.1s;
                `}
                >
                    ▶
                </a>
            ) : (
                <span
                    style={`
                    display:inline-flex; align-items:center; justify-content:center;
                    width:36px; height:36px;
                    background: var(--bg-panel);
                    border: 3px solid var(--bg-border);
                    color: var(--text-dim);
                    font-size: 16px;
                    opacity: 0.4;
                `}
                >
                    ▶
                </span>
            )}
        </nav>
    )
}

<style>
    .pagination-btn:hover {
        border-color: var(--green-dark) !important;
        color: var(--yellow-light) !important;
        transform: translate(-1px, -1px);
        box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.4) !important;
    }
    .pagination-num:hover {
        border-color: var(--green-dark) !important;
        color: var(--yellow-light) !important;
    }
</style>

---
const { page } = Astro.props;

// Determine which page numbers to show
// We want to show: 1 ... 4 5 6 ... 10
// Or if few pages: 1 2 3 4 5
const totalPages = page.lastPage;
const currentPage = page.currentPage;
const range = 2; // How many pages around current to show

let pages = [];

// Always include page 1
pages.push(1);

for (let i = currentPage - range; i <= currentPage + range; i++) {
    if (i > 1 && i < totalPages) {
        if (pages[pages.length - 1] !== i - 1) {
            pages.push("...");
        }
        pages.push(i);
    }
}

// Always include last page if it's not 1
if (totalPages > 1) {
    if (pages[pages.length - 1] !== totalPages - 1) {
        pages.push("...");
    }
    pages.push(totalPages);
}

// Logic to fix the weird case where we might get 1 ... 2 or similar gaps logic can be simple
// If total pages is small (e.g. < 7), just show all
if (totalPages <= 7) {
    pages = Array.from({ length: totalPages }, (_, i) => i + 1);
}
---

{
    totalPages > 1 && (
        <nav
            class="flex justify-center items-center font-mono text-sm mt-12 mb-8"
            aria-label="Pagination"
        >
            {/* Previous Button (Design 1 Arrows) */}
            {page.url.prev ? (
                <a
                    href={page.url.prev}
                    class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 transition-colors"
                    aria-label="Previous page"
                >
                    <span class="text-xl">&larr;</span>
                </a>
            ) : (
                <span class="w-10 h-10 flex items-center justify-center rounded-full text-gray-300 dark:text-gray-700 cursor-not-allowed">
                    <span class="text-xl">&larr;</span>
                </span>
            )}

            <span class="mx-4 text-gray-300 dark:text-gray-700">|</span>

            {/* Page Numbers (Design 4 Tech Mono) */}
            <div class="flex items-center space-x-2">
                {pages.map((pageNum) => (
                    <>
                        {pageNum === "..." ? (
                            <span class="px-2 py-1 text-gray-400 dark:text-gray-600">
                                ...
                            </span>
                        ) : (
                            <a
                                href={
                                    pageNum === 1
                                        ? "/articles"
                                        : `/page/${pageNum}`.replace(
                                              "/page/1",
                                              "/articles",
                                          )
                                }
                                class={`
                                    border-b-2 px-2 py-1 transition-all
                                    ${
                                        pageNum === currentPage
                                            ? "border-indigo-600 font-bold text-indigo-600 dark:text-indigo-400 dark:border-indigo-400"
                                            : "border-transparent hover:border-indigo-600 text-gray-500 dark:text-gray-400 dark:hover:border-indigo-400"
                                    }
                                `}
                                aria-current={
                                    pageNum === currentPage ? "page" : undefined
                                }
                                onclick={
                                    pageNum === 1 &&
                                    typeof page.url.prev === "undefined"
                                        ? "event.preventDefault(); window.location.href='/articles'"
                                        : undefined
                                }
                            >
                                {String(pageNum).padStart(2, "0")}
                            </a>
                        )}
                    </>
                ))}
            </div>

            <span class="mx-4 text-gray-300 dark:text-gray-700">|</span>

            {/* Next Button (Design 1 Arrows) */}
            {page.url.next ? (
                <a
                    href={page.url.next}
                    class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 transition-colors"
                    aria-label="Next page"
                >
                    <span class="text-xl">&rarr;</span>
                </a>
            ) : (
                <span class="w-10 h-10 flex items-center justify-center rounded-full text-gray-300 dark:text-gray-700 cursor-not-allowed">
                    <span class="text-xl">&rarr;</span>
                </span>
            )}
        </nav>
    )
}
